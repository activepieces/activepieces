{
  "name": "worker",
  "version": "0.1.0",
  "type": "commonjs",
  "main": "./dist/src/index.js",
  "typings": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "serve": "cd ../../.. && npx tsx watch --tsconfig packages/server/worker/tsconfig.lib.json packages/server/worker/src/bootstrap.ts",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run"
  },
  "dependencies": {
    "@activepieces/core-utils": "workspace:*",
    "@activepieces/job-executor": "workspace:*",
    "@activepieces/sandbox-pool": "workspace:*",
    "@activepieces/server-utils": "workspace:*",
    "@activepieces/shared": "workspace:*",
    "dotenv": "16.4.7",
    "google-auth-library": "9.15.1",
    "nanoid": "3.3.8",
    "socket.io": "4.7.5",
    "socket.io-client": "4.8.1",
    "tslib": "2.6.2"
  },
  "devDependencies": {
    "@types/node": "24.11.0",
    "vitest": "3.0.8"
  }
}
