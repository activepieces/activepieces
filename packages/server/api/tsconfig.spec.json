{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "module": "commonjs",
    "types": ["vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@api/*": ["./src/app/*"]
    }
  },
  "include": [
    "types/**/*.d.ts",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "test/**/*.ts",
    "node_modules/fastify-raw-body/plugin.d.ts"
  ],
  "exclude": []
}
