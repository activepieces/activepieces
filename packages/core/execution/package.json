{
  "name": "@activepieces/core-execution",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@activepieces/core-utils": "workspace:*",
    "@activepieces/core-piece-types": "workspace:*",
    "dayjs": "1.11.9",
    "semver": "7.6.0",
    "socket.io-client": "4.8.1",
    "tslib": "2.6.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "24.11.0",
    "@types/semver": "7.5.6",
    "tsup": "8.3.5",
    "typescript": "5.5.4"
  }
}
