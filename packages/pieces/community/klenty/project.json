{
  "name": "pieces-klenty",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pieces/community/klenty/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/pieces/community/klenty",
        "tsConfig": "packages/pieces/community/klenty/tsconfig.lib.json",
        "packageJson": "packages/pieces/community/klenty/package.json",
        "main": "packages/pieces/community/klenty/src/index.ts",
        "assets": ["packages/pieces/community/klenty/*.md"],
        "buildableProjectDepsInPackageJsonType": "dependencies",
        "updateBuildableProjectDepsInPackageJson": true,
        "clean": false
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  },
  "tags": []
}
