{
  "name": "pieces-telnyx",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pieces/community/telnyx/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/pieces/community/telnyx",
        "tsConfig": "packages/pieces/community/telnyx/tsconfig.lib.json",
        "packageJson": "packages/pieces/community/telnyx/package.json",
        "main": "packages/pieces/community/telnyx/src/index.ts",
        "assets": [
          "packages/pieces/community/telnyx/*.md",
          {
            "input": "packages/pieces/community/telnyx/src/i18n",
            "output": "./src/i18n",
            "glob": "**/!(i18n.json)"
          }
        ],
        "buildableProjectDepsInPackageJsonType": "dependencies",
        "updateBuildableProjectDepsInPackageJson": true,
        "clean": false
      },
      "dependsOn": ["^build", "prebuild"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/pieces/community/telnyx",
        "command": "bun install --no-save --silent"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": []
}
