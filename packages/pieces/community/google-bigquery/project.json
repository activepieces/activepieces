{
  "name": "pieces-google-bigquery",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pieces/community/google-bigquery/src",
  "projectType": "library",
  "release": {
    "version": {
      "currentVersionResolver": "git-tag",
      "preserveLocalDependencyProtocols": false,
      "manifestRootsToUpdate": ["dist/{projectRoot}"]
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/pieces/community/google-bigquery",
        "tsConfig": "packages/pieces/community/google-bigquery/tsconfig.lib.json",
        "packageJson": "packages/pieces/community/google-bigquery/package.json",
        "main": "packages/pieces/community/google-bigquery/src/index.ts",
        "assets": ["packages/pieces/community/google-bigquery/*.md"],
        "buildableProjectDepsInPackageJsonType": "dependencies",
        "updateBuildableProjectDepsInPackageJson": true,
        "clean": false
      },
      "dependsOn": ["^build", "prebuild"]
    },
    "nx-release-publish": {
      "options": { "packageRoot": "dist/{projectRoot}" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/pieces/community/google-bigquery",
        "command": "bun install --no-save --silent"
      },
      "dependsOn": ["^build"]
    }
  }
}
