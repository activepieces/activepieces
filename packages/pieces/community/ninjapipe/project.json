{
  "name": "pieces-community-ninjapipe",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pieces/community/ninjapipe/src",
  "projectType": "library",
  "release": {
    "version": {
      "generatorOptions": {
        "packageRoot": "dist/{projectRoot}",
        "currentVersionResolver": "git-tag",
        "fallbackCurrentVersionResolver": "disk"
      }
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/pieces/community/ninjapipe",
        "tsConfig": "packages/pieces/community/ninjapipe/tsconfig.lib.json",
        "packageJson": "packages/pieces/community/ninjapipe/package.json",
        "main": "packages/pieces/community/ninjapipe/src/index.ts",
        "assets": ["packages/pieces/community/ninjapipe/*.md"],
        "buildableProjectDepsInBuildTopologyType": "dependencies"
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
