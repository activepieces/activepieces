{
  "name": "pieces-chargebee",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/pieces/community/chargebee/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/pieces/community/chargebee",
        "tsConfig": "packages/pieces/community/chargebee/tsconfig.lib.json",
        "packageJson": "packages/pieces/community/chargebee/package.json",
        "main": "packages/pieces/community/chargebee/src/index.ts",
        "assets": ["packages/pieces/community/chargebee/*.md"],
        "buildableProjectDepsInPackageJsonType": "dependencies",
        "updateBuildableProjectDepsInPackageJson": true,
        "clean": false
      },
      "dependsOn": ["^build", "prebuild"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/pieces/community/chargebee",
        "command": "bun install --no-save --silent"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": []
}
