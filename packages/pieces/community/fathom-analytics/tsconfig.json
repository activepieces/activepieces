{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@activepieces/pieces-framework": ["../../node_modules/@activepieces/pieces-framework/src/index.ts"],
      "@activepieces/pieces-common": ["../../node_modules/@activepieces/pieces-common/src/index.ts"],
      "@activepieces/shared": ["../../node_modules/@activepieces/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
