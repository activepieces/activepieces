#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

if [ ! -z "$SKIP_CHECK" ]; then
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha
do
    if [ "$remote_ref" = "refs/heads/main" ]; then
        echo "Direct pushes to 'main' are not allowed. Please use a feature branch and a pull request."
        exit 1
    fi
done

if [ "$CLAUDE_PUSH" = "yes" ]; then
  RUN_CHECKS="y"
elif [ -e /dev/tty ]; then
  printf "Run lint and tests before pushing? [Y/n] "
  read RUN_CHECKS < /dev/tty
else
  # No TTY and not Claude — skip checks (CI runs its own pipeline)
  RUN_CHECKS="n"
fi

case "$RUN_CHECKS" in
  [nN][oO]|[nN])
    echo "Skipping lint and tests."
    ;;
  *)
    echo "Running lint..."
    sudo npm run lint-dev || exit 1

    echo "Running tests..."
    sudo npm run test-unit || exit 1
    sudo npm run test-api || exit 1
    ;;
esac
