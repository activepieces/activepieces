#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Allow skipping this hook by setting SKIP_CHECK env variable
if [ ! -z "$SKIP_CHECK" ]; then
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha
do
    if [ "$remote_ref" = "refs/heads/main" ]; then
        echo "Direct pushes to 'main' are not allowed. Please use a feature branch and a pull request."
        exit 1
    fi
done

# Auto-approve when CLAUDE_PUSH=yes (injected by Claude Code hook)
if [ "$CLAUDE_PUSH" = "yes" ]; then
  RUN_CHECKS="y"
elif [ -e /dev/tty ]; then
  printf "Run lint and tests before pushing? [Y/n] "
  read RUN_CHECKS < /dev/tty
else
  RUN_CHECKS="y"
fi

case "$RUN_CHECKS" in
  [nN][oO]|[nN])
    echo "Skipping lint and tests."
    ;;
  *)
    echo "Running lint..."
    npm run lint

    echo "Running tests..."
    npx turbo run test --filter=@activepieces/engine --filter=@activepieces/shared
    npx turbo run test-ce test-ee test-cloud --filter=api
    ;;

esac