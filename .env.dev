AP_API_KEY=api-key

# Paths
AP_CACHE_PATH=./dev/cache
AP_CONFIG_PATH=./dev/config
AP_PORT=3000
AP_API_PORT=3000
# Environment
AP_ENVIRONMENT=dev
AP_LOG_LEVEL=debug
AP_LOG_PRETTY=true

# URLs (VERY IMPORTANT FIX)
AP_FRONTEND_URL=http://localhost:4200
AP_API_URL=http://localhost:3000/api
AP_WEBHOOK_URL=http://localhost:3000

# Database (dev mode = no postgres needed)
AP_DB_TYPE=PGLITE

# Queue (no Redis needed)
AP_QUEUE_MODE=MEMORY

# Features
AP_DEV_PIECES=google-sheets,store,stitch,stitch-google,stitch_google
AP_PIECES_SYNC_MODE=NONE
AP_LOAD_TRANSLATIONS_FOR_DEV_PIECES=false

# Timing
AP_TRIGGER_DEFAULT_POLL_INTERVAL=1
AP_WEBHOOK_TIMEOUT_SECONDS=30

# Auth / Security
AP_JWT_SECRET=dev-secret
AP_WORKER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjEifQ.eyJpZCI6ImRldi13b3JrZXIiLCJ0eXBlIjoiV09SS0VSIiwiaWF0IjoxNzcyODQyOTg4LCJleHAiOjQ5MjY0NDI5ODgsImlzcyI6ImFjdGl2ZXBpZWNlcyJ9.W1WmPY0gado-6xpsjx1mMKPLSikVnHkoa-VoWwY6jwQ

# Queue UI (optional)
AP_QUEUE_UI_ENABLED=true
AP_QUEUE_UI_USERNAME=admin
AP_QUEUE_UI_PASSWORD=admin

# Telemetry
AP_TELEMETRY_ENABLED=false