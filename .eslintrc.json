{
    "root": true,
    "ignorePatterns": ["**/*", "deploy/**/*"],
    "overrides": [
        {
            "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
            "rules": {
                "no-restricted-imports": [
                    "error",
                    {
                        "patterns": ["lodash", "lodash/*"]
                    }
                ]
            }
        }
    ]
}
