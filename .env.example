## ============================================================
## Activepieces Environment Configuration
## ============================================================
## It's advisable to consult the documentation and use the
## tools/deploy.sh script to generate passwords and keys,
## instead of manually filling them.
## Docs: https://www.activepieces.com/docs/install/configurations/environment-variables
## ============================================================

## --------------- Engine ---------------
AP_ENGINE_EXECUTABLE_PATH=dist/packages/engine/main.js

## --------------- Security Keys ---------------
## Random long password used for internal API authentication (optional for community edition)
AP_API_KEY=

## 256-bit encryption key (32 hex characters) — used to encrypt sensitive credentials
## Generate with: openssl rand -hex 16
AP_ENCRYPTION_KEY=

## Secret used to sign JWT tokens for user sessions
## Generate with: openssl rand -hex 32
AP_JWT_SECRET=

## --------------- General ---------------
AP_ENVIRONMENT=prod
AP_FRONTEND_URL=http://localhost:8080
AP_WEBHOOK_TIMEOUT_SECONDS=30
AP_TRIGGER_DEFAULT_POLL_INTERVAL=5

## --------------- PostgreSQL ---------------
AP_POSTGRES_DATABASE=activepieces
AP_POSTGRES_HOST=postgres
AP_POSTGRES_PORT=5432
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=

## --------------- Execution ---------------
AP_EXECUTION_MODE=UNSANDBOXED
AP_SANDBOX_RUN_TIME_SECONDS=600

## --------------- Redis ---------------
AP_REDIS_HOST=redis
AP_REDIS_PORT=6379

## --------------- Telemetry & Templates ---------------
AP_TELEMETRY_ENABLED=true
AP_TEMPLATES_SOURCE_URL="https://cloud.activepieces.com/api/v1/flow-templates"
